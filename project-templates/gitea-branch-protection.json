{
  "_comment": "Gitea branch protection template for main branch. Apply via Gitea API:",
  "_api": "POST /api/v1/repos/{owner}/{repo}/branches/main/protection",
  "_docs": "https://gitea.io/api/swagger#/repository/repoCreateBranchProtection",
  "branch_name": "main",
  "enable_push": false,
  "enable_push_whitelist": false,
  "push_whitelist_usernames": [],
  "push_whitelist_deploy_keys": false,
  "enable_merge_whitelist": false,
  "merge_whitelist_usernames": [],
  "enable_status_check": true,
  "status_check_contexts": [
    "Markdown lint",
    "Validate skill routing",
    "Verify skill counts",
    "Validate rule metadata",
    "Validate project templates"
  ],
  "require_signed_commits": false,
  "protected_file_patterns": "",
  "unprotected_file_patterns": "",
  "require_approvals": 0,
  "enable_approvals_whitelist": false,
  "approvals_whitelist_usernames": [],
  "block_on_official_review_requests": false,
  "block_on_rejected_reviews": false,
  "block_on_outdated_branch": false,
  "dismiss_stale_approvals": false,
  "ignore_stale_approvals": false
}
